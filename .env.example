# chatbotllm backend configuration
# Repo: https://github.com/Harkeerat-ai/chatbotllm
#
# --- Frontend (this site) ---
# Deployed API base URL (no trailing slash)
VITE_CHATBOT_API_URL=https://api.yourdomain.com
# Brand slug — must exist in chatbotllm (create via POST /api/brands or admin UI)
VITE_CHATBOT_BRAND=harkeerat
#
# --- Backend setup (chatbotllm repo, one-time) ---
# 1. Create brand: POST /api/brands { "slug": "harkeerat", "name": "Harkeerat Bhasin", ... }
# 2. Add knowledge/harkeerat/ with bio.md, projects.md, faq.json
# 3. Run: python seed.py
# 4. Start: uvicorn app.main:app --reload  (local) or deploy to your host
# 5. Set CORS allow_origins to your site domain in chatbotllm app/main.py for production
